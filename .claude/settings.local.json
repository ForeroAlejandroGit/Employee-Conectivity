{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(git config:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "source /c/ProgramData/anaconda3/etc/profile.d/conda.sh && conda activate ds-starter 2>/dev/null || true",
            "statusMessage": "Activating ds-starter conda environment..."
          }
        ]
      }
    ]
  }
}
